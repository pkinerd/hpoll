@page
@model Hpoll.Admin.Pages.AboutModel
@{
    ViewData["Title"] = "About";
}

<h1>About hpoll</h1>

<div class="cards">
    <div class="card">
        <h3>Customers</h3>
        <div class="value">@Model.CustomerCount</div>
    </div>
    <div class="card">
        <h3>Hubs</h3>
        <div class="value">@Model.HubCount</div>
    </div>
    <div class="card">
        <h3>Devices</h3>
        <div class="value">@Model.DeviceCount</div>
    </div>
</div>

@if (TempData["Error"] is string error)
{
    <div class="card" style="border-left:4px solid #c0392b; background:#fdf0ef;">
        <p style="color:#c0392b; margin:0;">@error</p>
    </div>
}

<h2>Database Export</h2>
<div class="card">
    <p>Download a sanitized copy of the database with sensitive fields (OAuth tokens, email addresses) removed.</p>
    <form method="post" asp-page-handler="ExportSanitizedDb">
        <button type="submit" style="padding:8px 16px; background:#2563eb; color:#fff; border:none; border-radius:4px; cursor:pointer;">Download Sanitized Database</button>
    </form>
</div>

@if (Model.BuildEntries.Count > 0)
{
    <h2>Admin Build</h2>
    <div class="card">
        <dl>
            @foreach (var entry in Model.BuildEntries)
            {
                <dt>@entry.Label</dt>
                <dd>@entry.Value</dd>
            }
        </dl>
    </div>
}

@if (Model.Sections.Count == 0)
{
    <div class="card">
        <p style="color:#666;">No system information available. The worker process has not started yet.</p>
    </div>
}
else
{
    @foreach (var group in Model.Sections)
    {
        <h2>@group.Category</h2>
        <div class="card">
            <dl>
                @foreach (var entry in group.Entries)
                {
                    <dt>@entry.Label</dt>
                    <dd>@entry.Value</dd>
                }
            </dl>
        </div>
    }
}
