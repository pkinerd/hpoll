@page
@model Hpoll.Admin.Pages.AboutModel
@{
    ViewData["Title"] = "About";
}

<style>.build-diff { color: darkred; }</style>

<h1>About hpoll</h1>

<div class="cards">
    <div class="card">
        <h3>Customers</h3>
        <div class="value">@Model.CustomerCount</div>
    </div>
    <div class="card">
        <h3>Hubs</h3>
        <div class="value">@Model.HubCount</div>
    </div>
    <div class="card">
        <h3>Devices</h3>
        <div class="value">@Model.DeviceCount</div>
    </div>
</div>

@if (Model.BuildEntries.Count > 0)
{
    <h2>Admin Build</h2>
    <div class="card">
        <dl>
            @foreach (var entry in Model.BuildEntries)
            {
                <dt>@entry.Label</dt>
                <dd class="@(Model.AdminBuildDiffLabels.Contains(entry.Label) ? "build-diff" : "")">@entry.Value</dd>
            }
        </dl>
    </div>
}

@if (Model.Sections.Count == 0)
{
    <div class="card">
        <p style="color:#666;">No system information available. The worker process has not started yet.</p>
    </div>
}
else
{
    @foreach (var group in Model.Sections)
    {
        <h2>@group.Category</h2>
        <div class="card">
            <dl>
                @foreach (var entry in group.Entries)
                {
                    <dt>@entry.Label</dt>
                    <dd class="@(group.Category == "Worker Build" && Model.WorkerBuildDiffLabels.Contains(entry.Label) ? "build-diff" : "")">@entry.Value</dd>
                }
            </dl>
        </div>
    }
}
