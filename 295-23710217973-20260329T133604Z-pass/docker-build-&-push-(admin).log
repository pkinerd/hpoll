2026-03-29T13:35:50.3815554Z               },
2026-03-29T13:35:50.3815742Z               "distinct": false,
2026-03-29T13:35:50.3816012Z               "id": "f15fe6fbc5ad85c037447ab944384fbd3e9b4dac",
2026-03-29T13:35:50.3818708Z               "message": "Fix battery and connectivity not showing on admin detail page\n\nGetOrCreateDeviceAsync stores one device per HueDeviceId (the physical\ndevice), so the DeviceType reflects whichever resource was polled first\n(typically motion). Querying by DeviceType == Battery found nothing.\n\nFix: query DeviceReadings by ReadingType instead of filtering Devices by\nDeviceType. This matches how EmailRenderer already queries the data.\n\nhttps://claude.ai/code/session_01N2A7MASDjYVWA5SWYBa7rP",
2026-03-29T13:35:50.3821040Z               "timestamp": "2026-03-29T11:45:30Z",
2026-03-29T13:35:50.3821363Z               "tree_id": "91db4a0168faf0d8822d606d859006a264af0d97",
2026-03-29T13:35:50.3821878Z               "url": "https://github.com/***/hpoll/commit/f15fe6fbc5ad85c037447ab944384fbd3e9b4dac"
2026-03-29T13:35:50.3822275Z             },
2026-03-29T13:35:50.3822444Z             {
2026-03-29T13:35:50.3822617Z               "author": {
2026-03-29T13:35:50.3822847Z                 "email": "noreply@anthropic.com",
