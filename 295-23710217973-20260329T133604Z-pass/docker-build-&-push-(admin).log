2026-03-29T13:35:50.3813182Z                 "name": "Claude",
2026-03-29T13:35:50.3813472Z                 "username": "claude"
2026-03-29T13:35:50.3814146Z               },
2026-03-29T13:35:50.3814358Z               "committer": {
2026-03-29T13:35:50.3814609Z                 "email": "noreply@anthropic.com",
2026-03-29T13:35:50.3814911Z                 "name": "Claude",
