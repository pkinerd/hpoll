2026-03-29T16:02:05.8798225Z                 "name": "Claude",
2026-03-29T16:02:05.8798450Z                 "username": "claude"
2026-03-29T16:02:05.8798652Z               },
2026-03-29T16:02:05.8798823Z               "committer": {
2026-03-29T16:02:05.8799046Z                 "email": "noreply@anthropic.com",
2026-03-29T16:02:05.8799278Z                 "name": "Claude",
