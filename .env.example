# Hue application credentials
HueApp__ClientId=
HueApp__ClientSecret=
HueApp__CallbackUrl=http://localhost:8080/Hubs/OAuthCallback

# Email settings
Email__FromAddress=
Email__AwsRegion=us-east-1
Email__SendTimesUtc__0=08:00

# AWS credentials for SES email delivery
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Admin panel password hash (generate via the setup page at /Login)
ADMIN_PASSWORD_HASH=

# Polling interval (minutes)
Polling__IntervalMinutes=60

# Battery poll interval — 84 hours polls roughly twice per week
# Polling__BatteryPollIntervalHours=84

# Hours to keep device readings before cleanup (default 168 = 7 days)
# Polling__DataRetentionHours=168

# Token refresh: check every 24h, refresh when <48h until expiry
# Polling__TokenRefreshCheckHours=24
# Polling__TokenRefreshThresholdHours=48

# Email summary: 7 windows of 4 hours each = 28-hour coverage
# Email__SummaryWindowHours=4
# Email__SummaryWindowCount=7
